{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ESNext"],
		"types": ["bun-types", "node"],
		"jsx": "react-jsx",
		"jsxImportSource": "@opentui/react",
		"paths": {
			"@core/*": ["./src/core/*"],
			"@ui/*": ["./src/ui/*"]
		}
	},
	"include": ["src/**/*", "tests/**/*", "vitest.config.ts"]
}
