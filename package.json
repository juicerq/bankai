{
	"name": "project-j",
	"version": "0.0.1",
	"private": true,
	"description": "Canvas of live Claude Code sessions per project, with turn-by-turn code review — Electron + JSON store + ORPC + TanStack",
	"author": {
		"name": "juicerq",
		"email": "julio.cerqueiira@gmail.com"
	},
	"homepage": "https://github.com/juicerq/project-j",
	"repository": {
		"type": "git",
		"url": "https://github.com/juicerq/project-j.git"
	},
	"productName": "Project J",
	"appId": "io.github.juicerq.project-j",
	"type": "module",
	"main": "./out/main/index.js",
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
		"build": "electron-vite build",
		"preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
		"dist": "electron-vite build && electron-builder --publish never",
		"dist:linux": "electron-vite build && electron-builder --linux --publish never",
		"dist:win": "electron-vite build && electron-builder --win --publish never",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "lobomfz-check",
		"check:fix": "lobomfz-check --fix",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run check"
	},
	"dependencies": {
		"@lydell/node-pty": "^1.2.0-beta.12",
		"@orpc/client": "^1.14.0",
		"@orpc/server": "^1.14.0",
		"@orpc/tanstack-query": "^1.14.0",
		"@tanstack/react-query": "^5.99.2",
		"@tanstack/react-router": "^1.168.23",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"@xyflow/react": "^12.11.1",
		"arktype": "^2.2.0",
		"electron-updater": "^6.8.3",
		"lucide-react": "^1.23.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@lobomfz/check": "^0.1.10",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/router-plugin": "^1.167.22",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.0.0",
		"bun-types": "^1.3.13",
		"electron": "^33.0.0",
		"electron-builder": "^25.1.8",
		"electron-vite": "^4.0.0",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.0",
		"vite": "^6.0.0",
		"vitest": "^4.1.5"
	}
}
