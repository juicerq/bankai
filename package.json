{
	"name": "project-j",
	"version": "0.0.1",
	"private": true,
	"description": "Terminal cockpit for live Claude Code sessions per project, with turn-by-turn code review — openTUI + Bun + JSON store",
	"author": {
		"name": "juicerq",
		"email": "julio.cerqueiira@gmail.com"
	},
	"homepage": "https://github.com/juicerq/project-j",
	"repository": {
		"type": "git",
		"url": "https://github.com/juicerq/project-j.git"
	},
	"type": "module",
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"dev": "bun --watch src/index.tsx",
		"start": "bun src/index.tsx",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "lobomfz-check",
		"check:fix": "lobomfz-check --fix",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun run check"
	},
	"dependencies": {
		"@opentui/core": "0.4.3",
		"@opentui/react": "0.4.3",
		"@xterm/headless": "6.0.0",
		"arktype": "^2.2.0",
		"react": "^19.2.5"
	},
	"devDependencies": {
		"@lobomfz/check": "^0.1.10",
		"@types/react": "^19.2.14",
		"bun-types": "^1.3.13",
		"oxlint": "^1.62.0",
		"oxlint-tsgolint": "^0.22.1",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5.9.0",
		"vitest": "^4.1.5"
	}
}
